# Doctoringo AI — Frontend Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# Production values are injected via Google Cloud Build / Cloud Run secrets.

# ─── Supabase (required) ────────────────────────────────────────────────────
# Project URL and anon (public) key. Anon key is safe to ship to the browser
# because Postgres Row-Level Security policies enforce per-user access.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── xAI Grok (guest mode only) ─────────────────────────────────────────────
# WARNING: this key is bundled into the JS sent to anonymous users so they can
# chat without a Supabase session. Use a SEPARATE, low-quota key for guest use.
# Logged-in users go through the Supabase Edge Function which holds the real,
# high-quota key on the server side.
VITE_XAI_API_KEY=your_low_quota_xai_key_for_guests

# ─── Firebase (optional, analytics + auth) ──────────────────────────────────
# Web API keys are public identifiers, not secrets — but you should still
# create a project per environment and lock domains via Firebase console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Sentry (optional, error tracking) ──────────────────────────────────────
# When unset, ErrorBoundary silently no-ops. Install @sentry/react if you set
# this and want to receive events.
VITE_SENTRY_DSN=
